# Database Configuration
DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase Configuration
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SECRET_KEY=your_supabase_anon_key_here

# Google OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_SECRET=your_google_oauth_secret_here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# URLs Configuration
PASSWORD_RESET_REDIRECT_URL=http://localhost:3000/reset-password
CLIENT_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:8080/auth/google/callback
CLIENT_INVITE_REDIRECT_UTL="http://localhost:3000/invite/accept"

# Other Configuration
PASSWORD_RECOVERY_TIME=3600

# Application Configuration
NODE_ENV=development
DD_PORT=8080 

# SMTP Configuration
SMTP_USER=your_gmail_address@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_PASS=your_gmail_app_password 

COMPANY_INVITATION_EXPIRE_TIME=259200000

